# Empresa cuyos documentos se procesarán.
# Copia este archivo como .env y reemplaza el valor por una carpeta existente.
EMPRESA_ACTIVA=NombreEmpresa

# El agente interno podrá consultar ambos niveles.
VISIBILIDADES_PERMITIDAS=Public,Private

# Configuración de embeddings e índice local
GEMINI_API_KEY=tu_clave_de_gemini
EMBEDDING_MODEL=models/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
VECTORSTORE_DIR=.vectorstore
